# ── Server ──────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000

# ── Database (Postgres) ────────────────
DATABASE_URL=postgres://estatiq:estatiq_pass@localhost:5432/estatiq_dev
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis (sessions / rate limit / cache) ──
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── SaaS / Billing ──────────────────────
TRIAL_PERIOD_DAYS=14
DEFAULT_PLAN_CODE=starter

# ── CORS ────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── File storage (S3-compatible) ───────
S3_ENDPOINT=
S3_BUCKET=estatiq-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1

# ── Email (transactional) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Estatiq <no-reply@estatiq.in>
